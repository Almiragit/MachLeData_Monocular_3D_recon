FROM python:3.11-slim

WORKDIR /app

# Install deps at BUILD time — not at runtime
RUN pip install --no-cache-dir \
    streamlit==1.35.0 \
    requests>=2.31.0 \
    pillow>=10.0.0 \
    numpy>=1.26.0 \
    plotly>=5.20.0

COPY app/ ./app/

EXPOSE 8501

CMD ["streamlit", "run", "app/frontend/app.py", \
     "--server.port=8501", \
     "--server.address=0.0.0.0", \
     "--server.headless=true"]
