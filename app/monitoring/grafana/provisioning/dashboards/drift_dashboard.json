{
  "title": "MLOps Drift Monitoring",
  "uid": "mlops-drift",
  "version": 1,
  "timezone": "browser",
  "panels": [
    {
      "title": "PSI Score - Brightness",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "drift_input_brightness_psi", "legendFormat": "PSI"}],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "thresholds": [
        {"color": "green", "value": null},
        {"color": "orange", "value": 0.1},
        {"color": "red", "value": 0.25}
      ]
    },
    {
      "title": "PSI Score - Contrast",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "drift_input_contrast_psi", "legendFormat": "PSI"}],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "thresholds": [
        {"color": "green", "value": null},
        {"color": "orange", "value": 0.1},
        {"color": "red", "value": 0.25}
      ]
    },
    {
      "title": "PSI Score - Blur",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "drift_input_blur_psi", "legendFormat": "PSI"}],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "thresholds": [
        {"color": "green", "value": null},
        {"color": "orange", "value": 0.1},
        {"color": "red", "value": 0.25}
      ]
    },
    {
      "title": "Alert Status",
      "type": "stat",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "drift_alert_triggered", "legendFormat": "Alert"}],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "thresholds": [
        {"color": "green", "value": null},
        {"color": "red", "value": 1}
      ]
    },
    {
      "title": "Depth Mean (Rolling)",
      "type": "graph",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [{"expr": "drift_pred_depth_mean", "legendFormat": "Depth Mean"}],
      "options": {"legend": {"show": true}}
    },
    {
      "title": "Invalid Depth Ratio",
      "type": "graph",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [{"expr": "drift_pred_invalid_ratio", "legendFormat": "Invalid Ratio"}],
      "options": {"legend": {"show": true}},
      "thresholds": [
        {"color": "green", "value": null},
        {"color": "red", "value": 0.3}
      ]
    }
  ],
  "refresh": "15s",
  "tags": ["mlops", "drift", "monocular-3d-recon"],
  "editable": true
}