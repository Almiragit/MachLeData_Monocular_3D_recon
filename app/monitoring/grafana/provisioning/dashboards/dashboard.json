{
  "annotations": { "list": [] },
  "description": "MLOps monitoring — API metrics + Drift Detection (Stage 4 & 5)",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100, "title": "── Stage 4: API Performance ──", "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [{"color":"green","value":null},{"color":"red","value":50}] } } },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1, "title": "Request Rate", "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "rate(http_requests_total[1m])", "legendFormat": "req/s" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [{"color":"green","value":null},{"color":"yellow","value":500},{"color":"red","value":2000}] } } },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2, "title": "P95 Latency", "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m])) * 1000",
        "legendFormat": "p95 ms" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [{"color":"green","value":null},{"color":"red","value":1}] } } },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3, "title": "Error Rate (4xx/5xx)", "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "rate(http_requests_total{status=~\"4..|5..\"}[1m])",
        "legendFormat": "errors/s" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4, "title": "Total Requests", "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "http_requests_total", "legendFormat": "total" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 5, "title": "Request Latency (p50 / p95 / p99)", "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket[5m])) * 1000", "legendFormat": "p50" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m])) * 1000", "legendFormat": "p95" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[5m])) * 1000", "legendFormat": "p99" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "id": 6, "title": "Requests/s by Endpoint", "type": "timeseries",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "rate(http_requests_total[1m])", "legendFormat": "{{handler}} {{method}}" }]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 200, "title": "── Stage 5: Drift Detection ──", "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "max": 1,
        "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [
          {"color":"green","value":null}, {"color":"red","value":1}
        ] } } },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 14 },
      "id": 20, "title": "🚨 Drift Alert", "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background",
        "textMode": "value_and_name" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "drift_alert_triggered", "legendFormat": "alert" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0,
        "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [
          {"color":"green","value":null}, {"color":"yellow","value":0.10}, {"color":"red","value":0.25}
        ] } } },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 14 },
      "id": 21, "title": "PSI — Brightness", "type": "gauge",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "drift_input_brightness_psi", "legendFormat": "PSI brightness" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0,
        "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [
          {"color":"green","value":null}, {"color":"yellow","value":0.10}, {"color":"red","value":0.25}
        ] } } },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 14 },
      "id": 22, "title": "PSI — Blur (Laplacian)", "type": "gauge",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "drift_input_blur_psi", "legendFormat": "PSI blur" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1,
        "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [
          {"color":"green","value":null}, {"color":"yellow","value":0.15}, {"color":"red","value":0.30}
        ] } } },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 14 },
      "id": 23, "title": "Invalid Depth Ratio", "type": "gauge",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "drift_pred_invalid_ratio", "legendFormat": "invalid ratio" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "id": 24, "title": "Drift PSI Scores Over Time", "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "drift_input_brightness_psi", "legendFormat": "brightness PSI" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "drift_input_blur_psi", "legendFormat": "blur PSI" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "drift_input_contrast_psi", "legendFormat": "contrast PSI" }
      ],
      "options": { "thresholds": { "steps": [
        {"color":"green","value":null}, {"color":"yellow","value":0.10}, {"color":"red","value":0.25}
      ] } }
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "id": 25, "title": "Predicted Depth Stats Over Time", "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "drift_pred_depth_mean", "legendFormat": "depth mean" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "drift_pred_depth_std", "legendFormat": "depth std" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "drift_pred_invalid_ratio", "legendFormat": "invalid ratio" }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["mlops", "fastapi", "drift", "depth-estimation"],
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "title": "Monocular 3D Reconstruction — Full MLOps Dashboard",
  "uid": "machle-full-dashboard",
  "version": 2
}
