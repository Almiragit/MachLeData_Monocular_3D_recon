FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir prometheus-client requests pyyaml

COPY src/ ./src/
COPY dvc.yaml ./dvc.yaml
COPY configs/ ./configs/

RUN mkdir -p artifacts/logs

CMD ["python", "src/training/retrain_trigger.py", "--interval", "300"]